{
  "name": "emergency-response-desktop",
  "version": "1.0.0",
  "description": "Emergency Response System Desktop Application",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "npm run bundle:server && electron-builder",
    "build:exe": "npm run bundle:server && electron-builder --win",
    "bundle:server": "npx @vercel/ncc build src/server/index.js -o src/server/dist"
  },
  "keywords": [
    "emergency",
    "electron",
    "iot"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@supabase/supabase-js": "^2.47.10",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "serialport": "^13.0.0",
    "uuid": "^11.0.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "@vercel/ncc": "^0.38.4"
  },
  "build": {
    "appId": "com.emergency.response",
    "productName": "Emergency Response",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "npmRebuild": false,
    "extraResources": [
      {
        "from": "../.env",
        "to": ".env"
      }
    ],
    "files": [
      "src/**/*",
      "assets/**/*"
    ],
    "asar": true,
    "electronDist": "node_modules/electron/dist"
  }
}
