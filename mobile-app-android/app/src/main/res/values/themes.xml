<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base App Theme - Dark -->
    <style name="Theme.EmergencyResponse" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/blue_accent</item>
        <item name="colorPrimaryVariant">@color/blue_accent_light</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/amber_400</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="android:statusBarColor">@color/black</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:windowBackground">@color/bg_dark</item>
    </style>

    <!-- Dialog Theme -->
    <style name="Theme.EmergencyResponse.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorSurface">@color/surface_light</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="materialAlertDialogTitleTextStyle">@style/DialogTitleStyle</item>
    </style>

    <style name="DialogTitleStyle" parent="MaterialAlertDialog.Material3.Title.Text">
        <item name="android:textColor">@color/white</item>
    </style>

</resources>
